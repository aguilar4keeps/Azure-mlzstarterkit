{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Deployment location."
      }
    },
    "deploymentNameSuffix": {
      "type": "string",
      "defaultValue": "[utcNow('yyyyMMddHHmmss')]",
      "metadata": {
        "description": "Suffix used to keep deployment names unique."
      }
    },
    "identifier": {
      "type": "string",
      "maxLength": 3,
      "metadata": {
        "description": "MLZ identifier (max 3 chars)."
      }
    },
    "environmentAbbreviation": {
      "type": "string",
      "defaultValue": "dev",
      "allowedValues": [
        "dev",
        "test",
        "prod"
      ]
    },
    "deployBastion": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Deploy Bastion in core MLZ hub."
      }
    },
    "deployActivityLogDiagnosticSetting": {
      "type": "bool",
      "defaultValue": false
    },
    "deployDefender": {
      "type": "bool",
      "defaultValue": false
    },
    "deployPolicy": {
      "type": "bool",
      "defaultValue": false
    },
    "emailSecurityContact": {
      "type": "string",
      "defaultValue": "security@example.mil"
    },
    "virtualNetworkAddressPrefix": {
      "type": "string",
      "defaultValue": "10.60.0.0/24"
    },
    "subnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.60.0.0/24"
    },
    "workloadName": {
      "type": "string"
    },
    "workloadShortName": {
      "type": "string"
    },
    "prefix": {
      "type": "string"
    },
    "domainControllerPrivateIp": {
      "type": "string",
      "defaultValue": "10.60.0.10"
    },
    "additionalDnsServers": {
      "type": "array",
      "defaultValue": []
    },
    "adminUsername": {
      "type": "string"
    },
    "adminPassword": {
      "type": "secureString"
    },
    "safeModeAdminPassword": {
      "type": "secureString"
    },
    "domainName": {
      "type": "string"
    },
    "domainNetbiosName": {
      "type": "string"
    },
    "entraLoginPrincipalId": {
      "type": "string"
    },
    "entraPrincipalType": {
      "type": "string",
      "defaultValue": "Group",
      "allowedValues": [
        "User",
        "Group",
        "ServicePrincipal"
      ]
    },
    "assignVmAdminRole": {
      "type": "bool",
      "defaultValue": true
    },
    "assignVmUserRole": {
      "type": "bool",
      "defaultValue": false
    },
    "serverVmSize": {
      "type": "string",
      "defaultValue": "Standard_D4s_v5"
    },
    "clientVmSize": {
      "type": "string",
      "defaultValue": "Standard_D4s_v5"
    },
    "serverImagePublisher": {
      "type": "string",
      "defaultValue": "MicrosoftWindowsServer"
    },
    "serverImageOffer": {
      "type": "string",
      "defaultValue": "WindowsServer"
    },
    "serverImageSku": {
      "type": "string",
      "defaultValue": "2022-datacenter-g2"
    },
    "serverImageVersion": {
      "type": "string",
      "defaultValue": "latest"
    },
    "clientImagePublisher": {
      "type": "string",
      "defaultValue": "MicrosoftWindowsDesktop"
    },
    "clientImageOffer": {
      "type": "string",
      "defaultValue": "windows-11"
    },
    "clientImageSku": {
      "type": "string",
      "defaultValue": "win11-23h2-pro"
    },
    "clientImageVersion": {
      "type": "string",
      "defaultValue": "latest"
    }
  },
  "variables": {
    "coreDeploymentName": "[format('deploy-mlz-core-{0}', parameters('deploymentNameSuffix'))]",
    "tier3DeploymentName": "[format('deploy-tier3-{0}', parameters('deploymentNameSuffix'))]",
    "labVmDeploymentName": "[format('deploy-ad-entra-vms-{0}', parameters('deploymentNameSuffix'))]",
    "cspmCoverageDeploymentName": "[format('deploy-cspm-coverage-{0}', parameters('deploymentNameSuffix'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[variables('coreDeploymentName')]",
      "location": "[parameters('location')]",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "https://raw.githubusercontent.com/Azure/missionlz/main/src/mlz.json"
        },
        "parameters": {
          "deploymentNameSuffix": {
            "value": "[parameters('deploymentNameSuffix')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "identifier": {
            "value": "[parameters('identifier')]"
          },
          "environmentAbbreviation": {
            "value": "[parameters('environmentAbbreviation')]"
          },
          "deployBastion": {
            "value": "[parameters('deployBastion')]"
          },
          "deployActiveDirectoryDomainServices": {
            "value": false
          },
          "deployLinuxVirtualMachine": {
            "value": false
          },
          "deployWindowsVirtualMachine": {
            "value": false
          },
          "deployDefender": {
            "value": "[parameters('deployDefender')]"
          },
          "deployPolicy": {
            "value": "[parameters('deployPolicy')]"
          },
          "emailSecurityContact": {
            "value": "[parameters('emailSecurityContact')]"
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[variables('tier3DeploymentName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', variables('coreDeploymentName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "https://raw.githubusercontent.com/Azure/missionlz/main/src/add-ons/tier3/solution.json"
        },
        "parameters": {
          "deploymentNameSuffix": {
            "value": "[parameters('deploymentNameSuffix')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "identifier": {
            "value": "[parameters('identifier')]"
          },
          "environmentAbbreviation": {
            "value": "[parameters('environmentAbbreviation')]"
          },
          "deployActivityLogDiagnosticSetting": {
            "value": "[parameters('deployActivityLogDiagnosticSetting')]"
          },
          "deployDefender": {
            "value": "[parameters('deployDefender')]"
          },
          "deployPolicy": {
            "value": "[parameters('deployPolicy')]"
          },
          "emailSecurityContact": {
            "value": "[parameters('emailSecurityContact')]"
          },
          "firewallResourceId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', variables('coreDeploymentName')), '2025-04-01').outputs.azureFirewallResourceId.value]"
          },
          "hubStorageAccountResourceId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', variables('coreDeploymentName')), '2025-04-01').outputs.hubStorageAccountResourceId.value]"
          },
          "hubVirtualNetworkResourceId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', variables('coreDeploymentName')), '2025-04-01').outputs.hubVirtualNetworkResourceId.value]"
          },
          "logAnalyticsWorkspaceResourceId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', variables('coreDeploymentName')), '2025-04-01').outputs.logAnalyticsWorkspaceResourceId.value]"
          },
          "virtualNetworkAddressPrefix": {
            "value": "[parameters('virtualNetworkAddressPrefix')]"
          },
          "subnetAddressPrefix": {
            "value": "[parameters('subnetAddressPrefix')]"
          },
          "workloadName": {
            "value": "[parameters('workloadName')]"
          },
          "workloadShortName": {
            "value": "[parameters('workloadShortName')]"
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[variables('labVmDeploymentName')]",
      "location": "[parameters('location')]",
      "scope": "[format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, reference(resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName')), '2025-04-01').outputs.tier.value.resourceGroupName)]",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[uri(deployment().properties.templateLink.uri, 'templates/ad-entra-vms.json')]"
        },
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "prefix": {
            "value": "[parameters('prefix')]"
          },
          "subnetResourceId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName')), '2025-04-01').outputs.tier.value.subnetResourceId]"
          },
          "domainControllerPrivateIp": {
            "value": "[parameters('domainControllerPrivateIp')]"
          },
          "additionalDnsServers": {
            "value": "[parameters('additionalDnsServers')]"
          },
          "adminUsername": {
            "value": "[parameters('adminUsername')]"
          },
          "adminPassword": {
            "value": "[parameters('adminPassword')]"
          },
          "safeModeAdminPassword": {
            "value": "[parameters('safeModeAdminPassword')]"
          },
          "domainName": {
            "value": "[parameters('domainName')]"
          },
          "domainNetbiosName": {
            "value": "[parameters('domainNetbiosName')]"
          },
          "entraLoginPrincipalId": {
            "value": "[parameters('entraLoginPrincipalId')]"
          },
          "entraPrincipalType": {
            "value": "[parameters('entraPrincipalType')]"
          },
          "assignVmAdminRole": {
            "value": "[parameters('assignVmAdminRole')]"
          },
          "assignVmUserRole": {
            "value": "[parameters('assignVmUserRole')]"
          },
          "serverVmSize": {
            "value": "[parameters('serverVmSize')]"
          },
          "clientVmSize": {
            "value": "[parameters('clientVmSize')]"
          },
          "serverImagePublisher": {
            "value": "[parameters('serverImagePublisher')]"
          },
          "serverImageOffer": {
            "value": "[parameters('serverImageOffer')]"
          },
          "serverImageSku": {
            "value": "[parameters('serverImageSku')]"
          },
          "serverImageVersion": {
            "value": "[parameters('serverImageVersion')]"
          },
          "clientImagePublisher": {
            "value": "[parameters('clientImagePublisher')]"
          },
          "clientImageOffer": {
            "value": "[parameters('clientImageOffer')]"
          },
          "clientImageSku": {
            "value": "[parameters('clientImageSku')]"
          },
          "clientImageVersion": {
            "value": "[parameters('clientImageVersion')]"
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[variables('cspmCoverageDeploymentName')]",
      "location": "[parameters('location')]",
      "scope": "[format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, reference(resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName')), '2025-04-01').outputs.tier.value.resourceGroupName)]",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[uri(deployment().properties.templateLink.uri, 'templates/cspm-coverage.json')]"
        },
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "namePrefix": {
            "value": "[parameters('prefix')]"
          },
          "sqlAdminUsername": {
            "value": "[parameters('adminUsername')]"
          },
          "sqlAdminPassword": {
            "value": "[parameters('adminPassword')]"
          }
        }
      }
    }
  ],
  "outputs": {
    "coreDeploymentName": {
      "type": "string",
      "value": "[variables('coreDeploymentName')]"
    },
    "tier3ResourceGroupName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName')), '2025-04-01').outputs.tier.value.resourceGroupName]"
    },
    "tier3SubnetResourceId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName')), '2025-04-01').outputs.tier.value.subnetResourceId]"
    },
    "hubVirtualNetworkResourceId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', variables('coreDeploymentName')), '2025-04-01').outputs.hubVirtualNetworkResourceId.value]"
    }
  }
}
