{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Deployment location."
      }
    },
    "deploymentNameSuffix": {
      "type": "string",
      "defaultValue": "[utcNow()]",
      "metadata": {
        "description": "Suffix used to keep deployment names unique."
      }
    },
    "identifier": {
      "type": "string",
      "maxLength": 3,
      "metadata": {
        "description": "MLZ identifier (max 3 chars)."
      }
    },
    "environmentAbbreviation": {
      "type": "string",
      "defaultValue": "dev",
      "allowedValues": [
        "dev",
        "test",
        "prod"
      ]
    },
    "deployBastion": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Deploy Bastion in core MLZ hub."
      }
    },
    "deployActivityLogDiagnosticSetting": {
      "type": "bool",
      "defaultValue": false
    },
    "deployDefender": {
      "type": "bool",
      "defaultValue": false
    },
    "deployDefenderCspm": {
      "type": "bool",
      "defaultValue": false
    },
    "deployDefenderForServers": {
      "type": "bool",
      "defaultValue": false
    },
    "defenderForServersSubPlan": {
      "type": "string",
      "defaultValue": "P2",
      "allowedValues": [ "P1", "P2" ]
    },
    "deployDefenderForStorage": {
      "type": "bool",
      "defaultValue": false
    },
    "deployDefenderForSql": {
      "type": "bool",
      "defaultValue": false
    },
    "deployDefenderForContainers": {
      "type": "bool",
      "defaultValue": false
    },
    "deployDefenderForAppService": {
      "type": "bool",
      "defaultValue": false
    },
    "deployDefenderForKeyVault": {
      "type": "bool",
      "defaultValue": false
    },
    "deployDefenderForArm": {
      "type": "bool",
      "defaultValue": false
    },
    "deployDefenderForDns": {
      "type": "bool",
      "defaultValue": false
    },
    "deployDefenderForOssDb": {
      "type": "bool",
      "defaultValue": false
    },
    "deployDefenderForCosmosDb": {
      "type": "bool",
      "defaultValue": false
    },
    "deployDefenderForApis": {
      "type": "bool",
      "defaultValue": false
    },
    "deployPolicy": {
      "type": "bool",
      "defaultValue": false
    },
    "deployNist80053": {
      "type": "bool",
      "defaultValue": false
    },
    "deployNist800171": {
      "type": "bool",
      "defaultValue": false
    },
    "deployIl5": {
      "type": "bool",
      "defaultValue": false
    },
    "deploySentinel": {
      "type": "bool",
      "defaultValue": false
    },
    "emailSecurityContact": {
      "type": "string",
      "defaultValue": "security@example.mil"
    },
    "virtualNetworkAddressPrefix": {
      "type": "string",
      "defaultValue": "10.60.0.0/24"
    },
    "subnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.60.0.0/24"
    },
    "workloadName": {
      "type": "string"
    },
    "workloadShortName": {
      "type": "string"
    },
    "prefix": {
      "type": "string"
    },
    "domainControllerPrivateIp": {
      "type": "string",
      "defaultValue": "10.60.0.10"
    },
    "additionalDnsServers": {
      "type": "array",
      "defaultValue": []
    },
    "adminUsername": {
      "type": "string"
    },
    "adminPassword": {
      "type": "secureString"
    },
    "safeModeAdminPassword": {
      "type": "secureString"
    },
    "domainName": {
      "type": "string"
    },
    "domainNetbiosName": {
      "type": "string"
    },
    "autoCreateEntraGroup": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "When true, creates a new Entra security group and uses its Object ID for VM login RBAC."
      }
    },
    "entraGroupName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Display name for the auto-created Entra security group. Used only when autoCreateEntraGroup is true."
      }
    },
    "existingWorkspaceResourceId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Resource ID of an existing Log Analytics workspace. Leave empty to use the MLZ-provisioned workspace."
      }
    },
    "customWorkspaceName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional custom name for a new Log Analytics workspace created in the workload resource group."
      }
    },
    "cspmStorageAccountName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional custom Storage account name (3-24 chars, lowercase alphanumeric only)."
      }
    },
    "cspmAcrName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional custom Container Registry name (5-50 chars, alphanumeric)."
      }
    },
    "cspmSqlServerName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional custom SQL Server name (1-63 chars, lowercase, numbers, hyphens)."
      }
    },
    "cspmSqlDatabaseName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional custom SQL Database name. Defaults to 'defenderdb'."
      }
    },
    "cspmBlobContainerName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional custom Blob container name. Defaults to 'coverage-container'."
      }
    },
    "entraLoginPrincipalId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Object ID of the Entra user, group, or service principal for VM login. Leave empty when autoCreateEntraGroup is true."
      }
    },
    "entraPrincipalType": {
      "type": "string",
      "defaultValue": "Group",
      "allowedValues": [
        "User",
        "Group",
        "ServicePrincipal"
      ]
    },
    "assignVmAdminRole": {
      "type": "bool",
      "defaultValue": true
    },
    "assignVmUserRole": {
      "type": "bool",
      "defaultValue": false
    },
    "serverVmSize": {
      "type": "string",
      "defaultValue": "Standard_D4s_v5"
    },
    "clientVmSize": {
      "type": "string",
      "defaultValue": "Standard_D4s_v5"
    },
    "serverImagePublisher": {
      "type": "string",
      "defaultValue": "MicrosoftWindowsServer"
    },
    "serverImageOffer": {
      "type": "string",
      "defaultValue": "WindowsServer"
    },
    "serverImageSku": {
      "type": "string",
      "defaultValue": "2022-datacenter-g2"
    },
    "serverImageVersion": {
      "type": "string",
      "defaultValue": "latest"
    },
    "clientImagePublisher": {
      "type": "string",
      "defaultValue": "MicrosoftWindowsDesktop"
    },
    "clientImageOffer": {
      "type": "string",
      "defaultValue": "windows-11"
    },
    "clientImageSku": {
      "type": "string",
      "defaultValue": "win11-23h2-pro"
    },
    "clientImageVersion": {
      "type": "string",
      "defaultValue": "latest"
    },
    "deployMde": {
      "type": "bool",
      "defaultValue": false
    },
    "deployLinuxVm": {
      "type": "bool",
      "defaultValue": false
    },
    "linuxVmSize": {
      "type": "string",
      "defaultValue": "Standard_D2s_v5"
    },
    "linuxFlavor": {
      "type": "string",
      "defaultValue": "ubuntu-2204"
    }
  },
  "variables": {
    "coreDeploymentName": "[format('deploy-mlz-core-{0}', parameters('deploymentNameSuffix'))]",
    "tier3DeploymentName": "[format('deploy-tier3-{0}', parameters('deploymentNameSuffix'))]",
    "labVmDeploymentName": "[format('deploy-ad-entra-vms-{0}', parameters('deploymentNameSuffix'))]",
    "cspmCoverageDeploymentName": "[format('deploy-cspm-coverage-{0}', parameters('deploymentNameSuffix'))]",
    "sentinelDeploymentName": "[format('deploy-sentinel-{0}', parameters('deploymentNameSuffix'))]",
    "workspaceDeploymentName": "[format('deploy-law-{0}', parameters('deploymentNameSuffix'))]",
    "entraGroupUniqueName": "[if(empty(parameters('entraGroupName')), format('mlz-{0}-vm-users', parameters('prefix')), parameters('entraGroupName'))]",
    "resolvedEntraPrincipalId": "[if(parameters('autoCreateEntraGroup'), reference(resourceId('Microsoft.Graph/groups', variables('entraGroupUniqueName')), '2023-07-01-preview').id, parameters('entraLoginPrincipalId'))]",
    "resolvedWorkspaceResourceId": "[if(not(empty(parameters('existingWorkspaceResourceId'))), parameters('existingWorkspaceResourceId'), if(not(empty(parameters('customWorkspaceName'))), format('/subscriptions/{0}/resourceGroups/{1}/providers/Microsoft.OperationalInsights/workspaces/{2}', subscription().subscriptionId, reference(resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName')), '2025-04-01').outputs.tier.value.resourceGroupName, parameters('customWorkspaceName')), reference(resourceId('Microsoft.Resources/deployments', variables('coreDeploymentName')), '2025-04-01').outputs.logAnalyticsWorkspaceResourceId.value))]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[variables('coreDeploymentName')]",
      "location": "[parameters('location')]",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "https://raw.githubusercontent.com/Azure/missionlz/main/src/mlz.json"
        },
        "parameters": {
          "deploymentNameSuffix": {
            "value": "[parameters('deploymentNameSuffix')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "identifier": {
            "value": "[parameters('identifier')]"
          },
          "environmentAbbreviation": {
            "value": "[parameters('environmentAbbreviation')]"
          },
          "deployBastion": {
            "value": "[parameters('deployBastion')]"
          },
          "deployActiveDirectoryDomainServices": {
            "value": false
          },
          "deployLinuxVirtualMachine": {
            "value": false
          },
          "deployWindowsVirtualMachine": {
            "value": false
          },
          "deployDefender": {
            "value": "[parameters('deployDefender')]"
          },
          "deployPolicy": {
            "value": "[parameters('deployPolicy')]"
          },
          "emailSecurityContact": {
            "value": "[parameters('emailSecurityContact')]"
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[variables('tier3DeploymentName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', variables('coreDeploymentName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "https://raw.githubusercontent.com/Azure/missionlz/main/src/add-ons/tier3/solution.json"
        },
        "parameters": {
          "deploymentNameSuffix": {
            "value": "[parameters('deploymentNameSuffix')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "identifier": {
            "value": "[parameters('identifier')]"
          },
          "environmentAbbreviation": {
            "value": "[parameters('environmentAbbreviation')]"
          },
          "deployActivityLogDiagnosticSetting": {
            "value": "[parameters('deployActivityLogDiagnosticSetting')]"
          },
          "deployDefender": {
            "value": "[parameters('deployDefender')]"
          },
          "deployPolicy": {
            "value": "[parameters('deployPolicy')]"
          },
          "emailSecurityContact": {
            "value": "[parameters('emailSecurityContact')]"
          },
          "firewallResourceId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', variables('coreDeploymentName')), '2025-04-01').outputs.azureFirewallResourceId.value]"
          },
          "hubStorageAccountResourceId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', variables('coreDeploymentName')), '2025-04-01').outputs.hubStorageAccountResourceId.value]"
          },
          "hubVirtualNetworkResourceId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', variables('coreDeploymentName')), '2025-04-01').outputs.hubVirtualNetworkResourceId.value]"
          },
          "logAnalyticsWorkspaceResourceId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', variables('coreDeploymentName')), '2025-04-01').outputs.logAnalyticsWorkspaceResourceId.value]"
          },
          "virtualNetworkAddressPrefix": {
            "value": "[parameters('virtualNetworkAddressPrefix')]"
          },
          "subnetAddressPrefix": {
            "value": "[parameters('subnetAddressPrefix')]"
          },
          "workloadName": {
            "value": "[parameters('workloadName')]"
          },
          "workloadShortName": {
            "value": "[parameters('workloadShortName')]"
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[variables('labVmDeploymentName')]",
      "location": "[parameters('location')]",
      "scope": "[format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, reference(resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName')), '2025-04-01').outputs.tier.value.resourceGroupName)]",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[uri(deployment().properties.templateLink.uri, 'templates/ad-entra-vms.json')]"
        },
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "prefix": {
            "value": "[parameters('prefix')]"
          },
          "subnetResourceId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName')), '2025-04-01').outputs.tier.value.subnetResourceId]"
          },
          "domainControllerPrivateIp": {
            "value": "[parameters('domainControllerPrivateIp')]"
          },
          "additionalDnsServers": {
            "value": "[parameters('additionalDnsServers')]"
          },
          "adminUsername": {
            "value": "[parameters('adminUsername')]"
          },
          "adminPassword": {
            "value": "[parameters('adminPassword')]"
          },
          "safeModeAdminPassword": {
            "value": "[parameters('safeModeAdminPassword')]"
          },
          "domainName": {
            "value": "[parameters('domainName')]"
          },
          "domainNetbiosName": {
            "value": "[parameters('domainNetbiosName')]"
          },
          "entraLoginPrincipalId": {
            "value": "[variables('resolvedEntraPrincipalId')]"
          },
          "entraPrincipalType": {
            "value": "[parameters('entraPrincipalType')]"
          },
          "assignVmAdminRole": {
            "value": "[parameters('assignVmAdminRole')]"
          },
          "assignVmUserRole": {
            "value": "[parameters('assignVmUserRole')]"
          },
          "serverVmSize": {
            "value": "[parameters('serverVmSize')]"
          },
          "clientVmSize": {
            "value": "[parameters('clientVmSize')]"
          },
          "serverImagePublisher": {
            "value": "[parameters('serverImagePublisher')]"
          },
          "serverImageOffer": {
            "value": "[parameters('serverImageOffer')]"
          },
          "serverImageSku": {
            "value": "[parameters('serverImageSku')]"
          },
          "serverImageVersion": {
            "value": "[parameters('serverImageVersion')]"
          },
          "clientImagePublisher": {
            "value": "[parameters('clientImagePublisher')]"
          },
          "clientImageOffer": {
            "value": "[parameters('clientImageOffer')]"
          },
          "clientImageSku": {
            "value": "[parameters('clientImageSku')]"
          },
          "clientImageVersion": {
            "value": "[parameters('clientImageVersion')]"
          },
          "deployMde": {
            "value": "[parameters('deployMde')]"
          },
          "deployLinuxVm": {
            "value": "[parameters('deployLinuxVm')]"
          },
          "linuxVmSize": {
            "value": "[parameters('linuxVmSize')]"
          },
          "linuxFlavor": {
            "value": "[parameters('linuxFlavor')]"
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[variables('cspmCoverageDeploymentName')]",
      "location": "[parameters('location')]",
      "scope": "[format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, reference(resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName')), '2025-04-01').outputs.tier.value.resourceGroupName)]",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[uri(deployment().properties.templateLink.uri, 'templates/cspm-coverage.json')]"
        },
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "namePrefix": {
            "value": "[parameters('prefix')]"
          },
          "sqlAdminUsername": {
            "value": "[parameters('adminUsername')]"
          },
          "sqlAdminPassword": {
            "value": "[parameters('adminPassword')]"
          },
          "customStorageAccountName": {
            "value": "[parameters('cspmStorageAccountName')]"
          },
          "customAcrName": {
            "value": "[parameters('cspmAcrName')]"
          },
          "customSqlServerName": {
            "value": "[parameters('cspmSqlServerName')]"
          },
          "customSqlDatabaseName": {
            "value": "[parameters('cspmSqlDatabaseName')]"
          },
          "customBlobContainerName": {
            "value": "[parameters('cspmBlobContainerName')]"
          }
        }
      }
    },
    {
      "condition": "[and(not(empty(parameters('customWorkspaceName'))), empty(parameters('existingWorkspaceResourceId')))]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[variables('workspaceDeploymentName')]",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName'))]"
      ],
      "scope": "[format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, reference(resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName')), '2025-04-01').outputs.tier.value.resourceGroupName)]",
      "properties": {
        "mode": "Incremental",
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "workspaceName": { "type": "string" },
            "location": { "type": "string" }
          },
          "resources": [
            {
              "type": "Microsoft.OperationalInsights/workspaces",
              "apiVersion": "2023-09-01",
              "name": "[parameters('workspaceName')]",
              "location": "[parameters('location')]",
              "properties": {
                "sku": { "name": "PerGB2018" },
                "retentionInDays": 90
              }
            }
          ]
        },
        "parameters": {
          "workspaceName": { "value": "[parameters('customWorkspaceName')]" },
          "location": { "value": "[parameters('location')]" }
        }
      }
    },
    {
      "condition": "[parameters('deployDefenderCspm')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "CloudPosture",
      "properties": { "pricingTier": "Standard" }
    },
    {
      "condition": "[parameters('deployDefenderForServers')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "VirtualMachines",
      "properties": {
        "pricingTier": "Standard",
        "subPlan": "[parameters('defenderForServersSubPlan')]"
      }
    },
    {
      "condition": "[parameters('deployDefenderForStorage')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "StorageAccounts",
      "properties": { "pricingTier": "Standard" }
    },
    {
      "condition": "[parameters('deployDefenderForSql')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "SqlServerVirtualMachines",
      "properties": { "pricingTier": "Standard" }
    },
    {
      "condition": "[parameters('deployDefenderForContainers')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "Containers",
      "properties": { "pricingTier": "Standard" }
    },
    {
      "condition": "[parameters('deployDefenderForAppService')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "AppServices",
      "properties": { "pricingTier": "Standard" }
    },
    {
      "condition": "[parameters('deployDefenderForKeyVault')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "KeyVaults",
      "properties": { "pricingTier": "Standard" }
    },
    {
      "condition": "[parameters('deployDefenderForArm')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "Arm",
      "properties": { "pricingTier": "Standard" }
    },
    {
      "condition": "[parameters('deployDefenderForDns')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "Dns",
      "properties": { "pricingTier": "Standard" }
    },
    {
      "condition": "[parameters('deployDefenderForOssDb')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "OpenSourceRelationalDatabases",
      "properties": { "pricingTier": "Standard" }
    },
    {
      "condition": "[parameters('deployDefenderForCosmosDb')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "CosmosDbs",
      "properties": { "pricingTier": "Standard" }
    },
    {
      "condition": "[parameters('deployDefenderForApis')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "Api",
      "properties": { "pricingTier": "Standard" }
    },
    {
      "condition": "[parameters('deployNist80053')]",
      "type": "Microsoft.Authorization/policyAssignments",
      "apiVersion": "2022-06-01",
      "name": "assign-nist-800-53",
      "properties": {
        "displayName": "NIST SP 800-53 Rev. 5",
        "policyDefinitionId": "/providers/Microsoft.Authorization/policySetDefinitions/179d1daa-458f-4e47-8086-2a68d0d6c38f",
        "enforcementMode": "DoNotEnforce"
      }
    },
    {
      "condition": "[parameters('deployNist800171')]",
      "type": "Microsoft.Authorization/policyAssignments",
      "apiVersion": "2022-06-01",
      "name": "assign-nist-800-171",
      "properties": {
        "displayName": "NIST SP 800-171 Rev. 2",
        "policyDefinitionId": "/providers/Microsoft.Authorization/policySetDefinitions/03055927-78bd-4236-86c0-f36125a10dc9",
        "enforcementMode": "DoNotEnforce"
      }
    },
    {
      "condition": "[parameters('deployIl5')]",
      "type": "Microsoft.Authorization/policyAssignments",
      "apiVersion": "2022-06-01",
      "name": "assign-dod-il5",
      "properties": {
        "displayName": "DoD Impact Level 5",
        "policyDefinitionId": "/providers/Microsoft.Authorization/policySetDefinitions/f9a961fa-3241-4b20-adc4-6b8e936e3a43",
        "enforcementMode": "DoNotEnforce"
      }
    },
    {
      "condition": "[parameters('deploySentinel')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[variables('sentinelDeploymentName')]",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', variables('coreDeploymentName'))]",
        "[resourceId('Microsoft.Resources/deployments', variables('tier3DeploymentName'))]",
        "[resourceId('Microsoft.Resources/deployments', variables('workspaceDeploymentName'))]"
      ],
      "scope": "[format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, split(variables('resolvedWorkspaceResourceId'), '/')[4])]",
      "properties": {
        "mode": "Incremental",
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "workspaceResourceId": { "type": "string" },
            "workspaceName": { "type": "string" },
