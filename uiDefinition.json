{
  "$schema": "https://schema.management.azure.com/schemas/2021-09-09/uiFormDefinition.schema.json",
  "view": {
    "kind": "Form",
    "properties": {
      "title": "Mission Landing Zone AD + Entra One-Shot",
      "steps": [
        {
          "name": "basics",
          "label": "Basics",
          "elements": [
            {
              "name": "description",
              "type": "Microsoft.Common.TextBlock",
              "options": {
                "text": "Deploys MLZ core hub, Tier3 network, AD lab (1 DC, 2 member servers, 3 clients), Entra VM sign-in, and CSPM sample resources."
              }
            },
            {
              "name": "resourceScope",
              "type": "Microsoft.Common.ResourceScope",
              "location": {
                "resourceTypes": [
                  "Microsoft.Network/virtualNetworks",
                  "Microsoft.Network/azureFirewalls",
                  "Microsoft.Network/bastionHosts",
                  "Microsoft.OperationalInsights/workspaces",
                  "Microsoft.Compute/virtualMachines",
                  "Microsoft.Storage/storageAccounts",
                  "Microsoft.Sql/servers",
                  "Microsoft.ContainerRegistry/registries"
                ]
              }
            },
            {
              "name": "identifier",
              "type": "Microsoft.Common.TextBox",
              "label": "Resource Naming Identifier",
              "toolTip": "1-3 character identifier used in MLZ naming.",
              "constraints": {
                "required": true,
                "validations": [
                  {
                    "regex": "^[a-zA-Z0-9]{1,3}$",
                    "message": "Use 1-3 alphanumeric characters."
                  }
                ]
              }
            },
            {
              "name": "environmentAbbreviation",
              "type": "Microsoft.Common.DropDown",
              "label": "Environment Abbreviation",
              "defaultValue": "dev",
              "constraints": {
                "required": true,
                "allowedValues": [
                  {
                    "label": "dev",
                    "value": "dev"
                  },
                  {
                    "label": "test",
                    "value": "test"
                  },
                  {
                    "label": "prod",
                    "value": "prod"
                  }
                ]
              }
            },
            {
              "name": "workloadName",
              "type": "Microsoft.Common.TextBox",
              "label": "Workload Name",
              "toolTip": "1-10 character workload name for Tier3 deployment.",
              "constraints": {
                "required": true,
                "validations": [
                  {
                    "regex": "^[a-zA-Z0-9]{1,10}$",
                    "message": "Use 1-10 alphanumeric characters."
                  }
                ]
              }
            },
            {
              "name": "workloadShortName",
              "type": "Microsoft.Common.TextBox",
              "label": "Workload Short Name",
              "toolTip": "1-3 character workload short name.",
              "constraints": {
                "required": true,
                "validations": [
                  {
                    "regex": "^[a-zA-Z0-9]{1,3}$",
                    "message": "Use 1-3 alphanumeric characters."
                  }
                ]
              }
            },
            {
              "name": "prefix",
              "type": "Microsoft.Common.TextBox",
              "label": "Resource Prefix",
              "toolTip": "Prefix for VMs and CSPM resources.",
              "constraints": {
                "required": true,
                "validations": [
                  {
                    "regex": "^[a-zA-Z0-9-]{2,15}$",
                    "message": "Use 2-15 characters (letters, numbers, hyphen)."
                  }
                ]
              }
            }
          ]
        },
        {
          "name": "networking",
          "label": "Networking",
          "elements": [
            {
              "name": "deployBastion",
              "type": "Microsoft.Common.CheckBox",
              "label": "Deploy Bastion",
              "defaultValue": true
            },
            {
              "name": "virtualNetworkAddressPrefix",
              "type": "Microsoft.Common.TextBox",
              "label": "Tier3 Virtual Network CIDR",
              "defaultValue": "10.60.0.0/24",
              "constraints": {
                "required": true,
                "validations": [
                  {
                    "regex": "^(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)\\/(1[0-9]|2[0-8])$",
                    "message": "Enter a valid CIDR value."
                  }
                ]
              }
            },
            {
              "name": "subnetAddressPrefix",
              "type": "Microsoft.Common.TextBox",
              "label": "Tier3 Subnet CIDR",
              "defaultValue": "10.60.0.0/24",
              "constraints": {
                "required": true,
                "validations": [
                  {
                    "regex": "^(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)\\/(1[0-9]|2[0-8])$",
                    "message": "Enter a valid CIDR value."
                  }
                ]
              }
            },
            {
              "name": "domainControllerPrivateIp",
              "type": "Microsoft.Common.TextBox",
              "label": "Domain Controller Private IP",
              "defaultValue": "10.60.0.10",
              "constraints": {
                "required": true,
                "validations": [
                  {
                    "regex": "^(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)\\.(25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)$",
                    "message": "Enter a valid IPv4 address."
                  }
                ]
              }
            }
          ]
        },
        {
          "name": "securityCompliance",
          "label": "Security and Compliance",
          "elements": [
            {
              "name": "deployActivityLogDiagnosticSetting",
              "type": "Microsoft.Common.CheckBox",
              "label": "Deploy Activity Log Diagnostic Setting",
              "defaultValue": false
            },
            {
              "name": "deployDefender",
              "type": "Microsoft.Common.CheckBox",
              "label": "Deploy Defender for Cloud",
              "defaultValue": false
            },
            {
              "name": "deployPolicy",
              "type": "Microsoft.Common.CheckBox",
              "label": "Create policy assignments",
              "defaultValue": false
            },
            {
              "name": "emailSecurityContact",
              "type": "Microsoft.Common.TextBox",
              "label": "Security Contact Email",
              "defaultValue": "security@example.mil",
              "constraints": {
                "required": true,
                "validations": [
                  {
                    "regex": "^.+@.+\\..+$",
                    "message": "Enter a valid email address."
                  }
                ]
              }
            },
            {
              "name": "cspmNote",
              "type": "Microsoft.Common.InfoBox",
              "options": {
                "style": "Info",
                "text": "This deployment includes CSPM/CWPP sample coverage resources: SQL DB, Storage + Blob Container, ACR, and a nested Resource Manager deployment."
              }
            }
          ]
        },
        {
          "name": "identity",
          "label": "Identity",
          "elements": [
            {
              "name": "adminUsername",
              "type": "Microsoft.Common.TextBox",
              "label": "Admin Username",
              "constraints": {
                "required": true
              }
            },
            {
              "name": "adminPassword",
              "type": "Microsoft.Common.PasswordBox",
              "label": {
                "password": "Admin Password",
                "confirmPassword": "Confirm Admin Password"
              },
              "constraints": {
                "required": true,
                "regex": "^(?=.*?[A-Z])(?=.*?[a-z])(?=.*?[0-9])(?=.*?[#?!@$%^&*-]).{12,72}$",
                "validationMessage": "Use 12-72 chars with upper/lower/number/special."
              },
              "options": {
                "hideConfirmation": false
              }
            },
            {
              "name": "safeModeAdminPassword",
              "type": "Microsoft.Common.PasswordBox",
              "label": {
                "password": "Safe Mode Admin Password (DSRM)",
                "confirmPassword": "Confirm Safe Mode Admin Password"
              },
              "constraints": {
                "required": true,
                "regex": "^(?=.*?[A-Z])(?=.*?[a-z])(?=.*?[0-9])(?=.*?[#?!@$%^&*-]).{12,72}$",
                "validationMessage": "Use 12-72 chars with upper/lower/number/special."
              },
              "options": {
                "hideConfirmation": false
              }
            },
            {
              "name": "domainName",
              "type": "Microsoft.Common.TextBox",
              "label": "Domain Name",
              "placeholder": "corp.contoso.com",
              "constraints": {
                "required": true
              }
            },
            {
              "name": "domainNetbiosName",
              "type": "Microsoft.Common.TextBox",
              "label": "Domain NetBIOS Name",
              "placeholder": "CORP",
              "constraints": {
                "required": true
              }
            },
            {
              "name": "entraLoginPrincipalId",
              "type": "Microsoft.Common.TextBox",
              "label": "Entra Principal Object ID",
              "constraints": {
                "required": true,
                "validations": [
                  {
                    "regex": "^[0-9a-fA-F-]{36}$",
                    "message": "Enter a valid GUID."
                  }
                ]
              }
            },
            {
              "name": "entraPrincipalType",
              "type": "Microsoft.Common.DropDown",
              "label": "Entra Principal Type",
              "defaultValue": "Group",
              "constraints": {
                "required": true,
                "allowedValues": [
                  {
                    "label": "Group",
                    "value": "Group"
                  },
                  {
                    "label": "User",
                    "value": "User"
                  },
                  {
                    "label": "Service Principal",
                    "value": "ServicePrincipal"
                  }
                ]
              }
            },
            {
              "name": "assignVmAdminRole",
              "type": "Microsoft.Common.CheckBox",
              "label": "Assign Virtual Machine Administrator Login role",
              "defaultValue": true
            },
            {
              "name": "assignVmUserRole",
              "type": "Microsoft.Common.CheckBox",
              "label": "Assign Virtual Machine User Login role",
              "defaultValue": false
            }
          ]
        },
        {
          "name": "remoteAccess",
          "label": "Remote Access",
          "elements": [
            {
              "name": "serverImagePublisher",
              "type": "Microsoft.Common.DropDown",
              "label": "Server Image Publisher",
              "defaultValue": "MicrosoftWindowsServer",
              "constraints": {
                "required": true,
                "allowedValues": [
                  {
                    "label": "MicrosoftWindowsServer",
                    "value": "MicrosoftWindowsServer"
                  }
                ]
              }
            },
            {
              "name": "serverImageOffer",
              "type": "Microsoft.Common.DropDown",
              "label": "Server Image Offer",
              "defaultValue": "WindowsServer",
              "constraints": {
                "required": true,
                "allowedValues": [
                  {
                    "label": "WindowsServer",
                    "value": "WindowsServer"
                  }
                ]
              }
            },
            {
              "name": "serverImageSku",
              "type": "Microsoft.Common.DropDown",
              "label": "Server Image SKU",
              "defaultValue": "2022-datacenter-g2",
              "toolTip": "Marketplace server image SKU.",
              "constraints": {
                "required": true,
                "allowedValues": [
                  {
                    "label": "Windows Server 2019 Gen2",
                    "value": "2019-datacenter-gensecond"
                  },
                  {
                    "label": "Windows Server 2022 Gen2",
                    "value": "2022-datacenter-g2"
                  },
                  {
                    "label": "Windows Server 2025 Gen2",
                    "value": "2025-datacenter-azure-edition"
                  }
                ]
              }
            },
            {
              "name": "serverImageVersion",
              "type": "Microsoft.Common.TextBox",
              "label": "Server Image Version",
              "defaultValue": "latest",
              "toolTip": "Use 'latest' or provide a specific marketplace version.",
              "constraints": {
                "required": true
              }
            },
            {
              "name": "serverVmSize",
              "type": "Microsoft.Common.DropDown",
              "label": "Server VM Size",
              "toolTip": "Used for DC and member servers.",
              "defaultValue": "Standard_D4s_v5",
              "constraints": {
                "required": true,
                "allowedValues": [
                  { "label": "Standard_D2s_v5 (2 vCPUs, 8 GiB)", "value": "Standard_D2s_v5" },
                  { "label": "Standard_D4s_v5 (4 vCPUs, 16 GiB)", "value": "Standard_D4s_v5" },
                  { "label": "Standard_D8s_v5 (8 vCPUs, 32 GiB)", "value": "Standard_D8s_v5" },
                  { "label": "Standard_D16s_v5 (16 vCPUs, 64 GiB)", "value": "Standard_D16s_v5" },
                  { "label": "Standard_D2s_v4 (2 vCPUs, 8 GiB)", "value": "Standard_D2s_v4" },
                  { "label": "Standard_D4s_v4 (4 vCPUs, 16 GiB)", "value": "Standard_D4s_v4" }
                ]
              }
            },
            {
              "name": "clientImagePublisher",
              "type": "Microsoft.Common.DropDown",
              "label": "Client Image Publisher",
              "defaultValue": "MicrosoftWindowsDesktop",
              "constraints": {
                "required": true,
                "allowedValues": [
                  {
                    "label": "MicrosoftWindowsDesktop",
                    "value": "MicrosoftWindowsDesktop"
                  }
                ]
              }
            },
            {
              "name": "clientImageOffer",
              "type": "Microsoft.Common.DropDown",
              "label": "Client Image Offer",
              "defaultValue": "windows-11",
              "constraints": {
                "required": true,
                "allowedValues": [
                  {
                    "label": "Windows 11",
                    "value": "windows-11"
                  },
                  {
                    "label": "Windows 10",
                    "value": "windows-10"
                  }
                ]
              }
            },
            {
              "name": "clientImageSku",
              "type": "Microsoft.Common.DropDown",
              "label": "Client Image SKU",
              "defaultValue": "win11-23h2-pro",
              "toolTip": "Marketplace client image SKU.",
              "constraints": {
                "required": true,
                "allowedValues": "[if(equals(steps('remoteAccess').clientImageOffer, 'windows-10'), parse('[{\"label\":\"Windows 10 Pro 22H2\",\"value\":\"win10-22h2-pro\"},{\"label\":\"Windows 10 Enterprise 22H2\",\"value\":\"win10-22h2-ent\"}]'), parse('[{\"label\":\"Windows 11 Pro 23H2\",\"value\":\"win11-23h2-pro\"},{\"label\":\"Windows 11 Enterprise 23H2\",\"value\":\"win11-23h2-ent\"}]'))]"
              }
            },
            {
              "name": "clientImageVersion",
              "type": "Microsoft.Common.TextBox",
              "label": "Client Image Version",
              "defaultValue": "latest",
              "toolTip": "Use 'latest' or provide a specific marketplace version.",
              "constraints": {
                "required": true
              }
            },
            {
              "name": "clientVmSize",
              "type": "Microsoft.Common.DropDown",
              "label": "Client VM Size",
              "defaultValue": "Standard_D4s_v5",
              "constraints": {
                "required": true,
                "allowedValues": [
                  { "label": "Standard_D2s_v5 (2 vCPUs, 8 GiB)", "value": "Standard_D2s_v5" },
                  { "label": "Standard_D4s_v5 (4 vCPUs, 16 GiB)", "value": "Standard_D4s_v5" },
                  { "label": "Standard_D8s_v5 (8 vCPUs, 32 GiB)", "value": "Standard_D8s_v5" },
                  { "label": "Standard_D2s_v4 (2 vCPUs, 8 GiB)", "value": "Standard_D2s_v4" },
                  { "label": "Standard_D4s_v4 (4 vCPUs, 16 GiB)", "value": "Standard_D4s_v4" }
                ]
              }
            }
          ]
        },
        {
          "name": "tags",
          "label": "Tags",
          "elements": [
            {
              "name": "tags",
              "type": "Microsoft.Common.TagsByResource",
              "resources": [
                "Microsoft.Compute/virtualMachines",
                "Microsoft.Network/virtualNetworks",
                "Microsoft.Network/azureFirewalls",
                "Microsoft.Network/bastionHosts",
                "Microsoft.Storage/storageAccounts",
                "Microsoft.Sql/servers",
                "Microsoft.ContainerRegistry/registries"
              ]
            }
          ]
        }
      ]
    },
    "outputs": {
      "kind": "Subscription",
      "location": "[steps('basics').resourceScope.location.name]",
      "subscriptionId": "[steps('basics').resourceScope.subscription.id]",
      "parameters": {
        "identifier": "[steps('basics').identifier]",
        "environmentAbbreviation": "[steps('basics').environmentAbbreviation]",
        "workloadName": "[steps('basics').workloadName]",
        "workloadShortName": "[steps('basics').workloadShortName]",
        "prefix": "[steps('basics').prefix]",
        "deployBastion": "[steps('networking').deployBastion]",
        "location": "[steps('basics').resourceScope.location.name]",
        "deployActivityLogDiagnosticSetting": "[steps('securityCompliance').deployActivityLogDiagnosticSetting]",
        "deployDefender": "[steps('securityCompliance').deployDefender]",
        "deployPolicy": "[steps('securityCompliance').deployPolicy]",
        "emailSecurityContact": "[steps('securityCompliance').emailSecurityContact]",
        "virtualNetworkAddressPrefix": "[steps('networking').virtualNetworkAddressPrefix]",
        "subnetAddressPrefix": "[steps('networking').subnetAddressPrefix]",
        "domainControllerPrivateIp": "[steps('networking').domainControllerPrivateIp]",
        "adminUsername": "[steps('identity').adminUsername]",
        "adminPassword": "[steps('identity').adminPassword.password]",
        "safeModeAdminPassword": "[steps('identity').safeModeAdminPassword.password]",
        "domainName": "[steps('identity').domainName]",
        "domainNetbiosName": "[steps('identity').domainNetbiosName]",
        "entraLoginPrincipalId": "[steps('identity').entraLoginPrincipalId]",
        "entraPrincipalType": "[steps('identity').entraPrincipalType]",
        "assignVmAdminRole": "[steps('identity').assignVmAdminRole]",
        "assignVmUserRole": "[steps('identity').assignVmUserRole]",
        "serverVmSize": "[steps('remoteAccess').serverVmSize]",
        "clientVmSize": "[steps('remoteAccess').clientVmSize]",
        "serverImagePublisher": "[steps('remoteAccess').serverImagePublisher]",
        "serverImageOffer": "[steps('remoteAccess').serverImageOffer]",
        "serverImageSku": "[steps('remoteAccess').serverImageSku]",
        "serverImageVersion": "[steps('remoteAccess').serverImageVersion]",
        "clientImagePublisher": "[steps('remoteAccess').clientImagePublisher]",
        "clientImageOffer": "[steps('remoteAccess').clientImageOffer]",
        "clientImageSku": "[steps('remoteAccess').clientImageSku]",
        "clientImageVersion": "[steps('remoteAccess').clientImageVersion]"
      }
    }
  }
}
