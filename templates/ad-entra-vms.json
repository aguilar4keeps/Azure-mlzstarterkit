        "roleDefinitionId": "[variables('vmUserRoleDefinitionId')]",
        "principalId": "[parameters('entraLoginPrincipalId')]",
        "principalType": "[parameters('entraPrincipalType')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', variables('linuxVmName'))]"
      ]
    }
  ],
  "outputs": {
    "deployedVmNames": {
      "type": "array",
      "copy": {
        "count": "[length(variables('vmDefinitions'))]",
        "input": "[variables('vmDefinitions')[copyIndex()].name]"
      }
    },
    "domainControllerName": {
      "type": "string",
      "value": "[variables('vmDefinitions')[0].name]"
    },
    "domainControllerPrivateIp": {
      "type": "string",
      "value": "[parameters('domainControllerPrivateIp')]"
    }
  }
}
